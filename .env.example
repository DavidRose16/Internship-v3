# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — used by Claude for research, email generation, and revision
ANTHROPIC_API_KEY=sk-ant-...

# Hunter.io API key — used for contact discovery (domain search + email finder)
# Free tier: 25 searches/month. https://hunter.io
HUNTER_API_KEY=...

# Google Sheet ID — the alphanumeric ID in your sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID=...

# Exa API key — used for company discovery and website content fetch
# https://exa.ai
EXA_API_KEY=...

# ── Sheet config ───────────────────────────────────────────────────────────────

# Tab name in the Google Sheet (default: run_queue)
SHEET_TAB_NAME=run_queue

# ── Discovery config ───────────────────────────────────────────────────────────

# Search queries for Exa, separated by pipe characters (|)
# If omitted, 8 default queries targeting early-stage AI startups are used.
SEARCH_QUERIES=seed stage AI startup|early stage AI startup 2026|YC startup AI agents|AI developer tools startup|AI infrastructure startup seed|fintech AI startup early stage|consumer AI startup|agentic startup seed

# Max results to fetch per search query (default: 10)
MAX_PER_QUERY=10

# ── Per-stage run limits ───────────────────────────────────────────────────────
# Each limit caps how many rows are processed in a single stage run.
# Lower values let you test incrementally before committing to a full batch.

ANALYZE_LIMIT=10
WRITE_LIMIT=10
CONTACTS_LIMIT=10
TARGETS_LIMIT=10
DRAFTS_LIMIT=10

# ── Writing config ─────────────────────────────────────────────────────────────

# Extra instructions appended to the email generation prompt (optional).
# Example: "Mention that you are available immediately."
EXTRA_WRITING_INSTRUCTIONS=
