# --- Required ---

# Anthropic API key (for Claude — discovery, research, email generation)
ANTHROPIC_API_KEY=sk-ant-...

# Hunter.io API key (for finding email contacts)
HUNTER_API_KEY=...

# Google Sheet ID (the long string in the sheet URL)
GOOGLE_SHEET_ID=1abc...xyz

# --- Optional ---

# Tab/sheet name (default: Sheet1)
SHEET_TAB_NAME=Sheet1

# Comma-separated company categories to search
CATEGORIES=AI startups,infra startups,fintech startups,VC firms

# Max companies per run (start with 3 for testing)
MAX_COMPANIES=3

# Dry run mode — set to false to actually create Gmail drafts and write to sheet
# Default is true (safe mode)
DRY_RUN=true
